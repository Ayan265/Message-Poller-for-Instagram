{
  "manifest_version": 3,
  "name": "Message Poller for Instagram",
  "version": "1.2",
  "description": "Premium dashboard for your local Instagram message poller.",

  "action": {
    "default_popup": "popup.html",
    "default_title": "Message Poller",
    "default_icon": "message.png"
  },

  "icons": {
    "512": "message.png"
  },

  "permissions": [
    "nativeMessaging",
    "alarms",
    "storage"
  ],
  "host_permissions": [
    "*://*.instagram.com/*"
  ],

  "background": {
    "scripts": ["background.js"]
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "message-poller-pro-v2@linuxayan.com",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
