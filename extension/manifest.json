{
  "manifest_version": 3,
  "name": "IG Poller Dashboard",
  "version": "1.1",
  "description": "Premium dashboard for your local Instagram Poller.",

  "action": {
    "default_popup": "popup.html",
    "default_title": "IG Poller Dashboard"
  },

  "permissions": [
    "nativeMessaging",
    "alarms",
    "storage"
  ],

  "background": {
    "scripts": ["background.js"]
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "ig-poller@linuxayan.com",
      "strict_min_version": "109.0"
    }
  }
}
